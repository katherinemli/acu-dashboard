#!/bin/bash
set -e

BACKEND_USER=acu
INSTALL_DIR=/opt/acu

case "$1" in
    remove)
        echo "Removing ACU package..."
        systemctl daemon-reload
        ;;

    purge)
        echo "Purging ACU package (removing all data)..."

        # Remove installation directory
        if [ -d "$INSTALL_DIR" ]; then
            rm -rf "$INSTALL_DIR"
        fi

        # Remove runtime directories
        rm -rf /var/log/acu
        rm -rf /var/lib/acu

        # Remove service user
        if id "$BACKEND_USER" &>/dev/null; then
            userdel -r "$BACKEND_USER" 2>/dev/null || true
        fi

        systemctl daemon-reload
        echo "Purge complete."
        ;;

    upgrade|failed-upgrade|abort-install|abort-upgrade)
        ;;
esac

exit 0
