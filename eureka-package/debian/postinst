#!/bin/bash
set -e

PKG_NAME=eureka-acu
INSTALL_DIR=/opt/eureka
VENV_DIR=$INSTALL_DIR/venv
BACKEND_USER=eureka
BACKEND_GROUP=eureka

echo "Installing $PKG_NAME..."

# Create service user if not exists
if ! id "$BACKEND_USER" &>/dev/null; then
    useradd -r -s /bin/false -d $INSTALL_DIR -m $BACKEND_USER
    echo "Created user: $BACKEND_USER"
fi

# Setup Python venv for backend
echo "Setting up Python environment..."
mkdir -p $VENV_DIR
python3 -m venv $VENV_DIR
source $VENV_DIR/bin/activate
pip install -q -r $INSTALL_DIR/backend/requirements.txt

# Create log directory
mkdir -p /var/log/eureka
chown $BACKEND_USER:$BACKEND_GROUP /var/log/eureka
chmod 755 /var/log/eureka

# Create runtime directory
mkdir -p /var/lib/eureka
chown $BACKEND_USER:$BACKEND_GROUP /var/lib/eureka
chmod 755 /var/lib/eureka

# Set permissions
chown -R $BACKEND_USER:$BACKEND_GROUP $INSTALL_DIR
chmod 755 $INSTALL_DIR

# Enable systemd services
systemctl daemon-reload
systemctl enable eureka-backend.service
systemctl enable eureka-daemon.service

echo "$PKG_NAME installed successfully!"
echo ""
echo "Start services:"
echo "  systemctl start eureka-daemon"
echo "  systemctl start eureka-backend"
echo ""
echo "View logs:"
echo "  journalctl -u eureka-backend -f"
echo "  journalctl -u eureka-daemon -f"

exit 0
